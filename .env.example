# Database (PostgreSQL/Supabase)
DATABASE_URL="postgresql://user:password@localhost:5432/devprep?schema=public"

# NextAuth (Google OAuth)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secret-here"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# AI Provider Configuration
# AI_PROVIDER: "ollama" | "anthropic" | "openai" | "gemini"
# AI_ROUTING:  "single" (default) | "smart" (routes by category: coding→Haiku, technical→Flash, behavioral→GPT-4o-mini)
AI_PROVIDER="ollama"
AI_ROUTING="single"

# Ollama Settings (Local)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1:8b"

# Anthropic Settings (Production)
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# OpenAI Settings
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o-mini"

# Gemini Settings
# GEMINI_API_KEY="..."
# GEMINI_MODEL="gemini-2.0-flash"
