# ── Database (Supabase, transaction pooler port 6543) ─────────────────────────
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true&schema=devprep"
DIRECT_URL="postgresql://user:password@host:6543/postgres?schema=devprep"

# ── Auth (NextAuth v5) ─────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="generate-with: openssl rand -base64 32"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── AI Provider ────────────────────────────────────────────────────────────────
# AI_PROVIDER: "ollama" | "anthropic" | "gemini" | "openai"
# AI_ROUTING:  "single" (uses AI_PROVIDER for everything)
#              "smart"  (routes by category: coding/system_design→Anthropic,
#                        technical→Gemini, behavioral→OpenAI)
#              Falls back to AI_PROVIDER if a required API key is missing.
AI_PROVIDER="anthropic"
AI_ROUTING="single"

# ── Ollama (local dev, free) ───────────────────────────────────────────────────
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1:8b"

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
# Default: claude-haiku-4-5-20251001 — fast and cheap for interviews
# ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# ── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY="..."
# Default: gemini-flash-latest
# GEMINI_MODEL="gemini-flash-latest"

# ── OpenAI (optional, only needed for smart routing behavioral questions) ──────
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o-mini"
