    "autoprefixer": "^10.4.27",
    "eslint": "^9",
    "eslint-config-next": "^15.5.14",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8",
    "prisma": "~6.2.1",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^4.1.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
