    "@auth/prisma-adapter": "^2.11.1",
    "@google/generative-ai": "^0.24.1",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/client": "~6.2.1",
    "clsx": "latest",
    "date-fns": "^4.1.0",
    "jose": "^6.2.2",
    "lucide-react": "latest",
    "next": "^16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.8.3",
    "openai": "^6.33.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "latest",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@testing-library/jest-dom": "^6.9.1",
